{
    "manifest_version": 3,
    "name": "NoProc Global Music",
    "version": "2.0",
    "description": "Real-time music metadata and playback control for the NoProc dashboard.",

    "permissions": [
        "scripting",
        "tabs",
        "activeTab"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "content_scripts": [
        {
            "matches": [
                "http://localhost/*",
                "http://127.0.0.1/*",
                "file://*/*"
            ],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],

    "action": {
        "default_popup": "popup.html",
        "default_title": "NoProc Music"
    }
}
