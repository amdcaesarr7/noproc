const ImageTrail = () => {
  const containerRef = useRef(null);

  useEffect(() => {
    if (!containerRef.current) return;
    const container = containerRef.current;
    if (window.innerWidth <= 768) return; // Disable on mobile

    let mousePos = { x: 0, y: 0 };
    let lastMousePos = { x: 0, y: 0 };
    let cacheMousePos = { x: 0, y: 0 };
    let zIndexVal = 1;

    const images = Array.from(container.querySelectorAll('.trail-img')).map(el => ({
      el,
      inner: el.querySelector('.trail-img-inner'),
      rect: el.getBoundingClientRect()
    }));

    if (images.length === 0) return;

    let imgPosition = 0;
    const threshold = 80;

    const handlePointerMove = (e) => {
      const rect = container.getBoundingClientRect();
      mousePos = { x: e.clientX - rect.left, y: e.clientY - rect.top };
    };

    container.addEventListener('mousemove', handlePointerMove);

    const lerp = (a, b, n) => (1 - n) * a + n * b;
    const getDist = (p1, p2) => Math.hypot(p1.x - p2.x, p1.y - p2.y);

    let raf;
    const render = () => {
      let distance = getDist(mousePos, lastMousePos);
      cacheMousePos.x = lerp(cacheMousePos.x, mousePos.x, 0.1);
      cacheMousePos.y = lerp(cacheMousePos.y, mousePos.y, 0.1);

      if (distance > threshold) {
        // Show Next Image
        zIndexVal++;
        imgPosition = imgPosition < images.length - 1 ? imgPosition + 1 : 0;
        const img = images[imgPosition];
        gsap.killTweensOf(img.el);

        gsap.timeline()
          .fromTo(img.el, 
            { opacity: 1, scale: 1, zIndex: zIndexVal, x: cacheMousePos.x - img.rect.width / 2, y: cacheMousePos.y - img.rect.height / 2 },
            { duration: 0.4, ease: 'power1', x: mousePos.x - img.rect.width / 2, y: mousePos.y - img.rect.height / 2 }, 0)
          .to(img.el, { duration: 0.4, ease: 'power3', opacity: 0, scale: 0.2 }, 0.4);

        lastMousePos = { ...mousePos };
      }
      raf = requestAnimationFrame(render);
    };

    raf = requestAnimationFrame(render);

    return () => {
      container.removeEventListener('mousemove', handlePointerMove);
      cancelAnimationFrame(raf);
    };
  }, []);

  return (
    <div ref={containerRef} className="relative w-full h-[600px] overflow-hidden my-20 border border-white/10 rounded-3xl bg-black/20 hidden md:block cursor-target">
      <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white/20 font-display text-4xl font-bold tracking-widest pointer-events-none text-center">
        MOVE YOUR CURSOR<br/><span className="text-xl font-sans tracking-normal font-light">To reveal the timeline</span>
      </div>
      
      {/* 5 Trail Images */}
      {[1, 2, 3, 4, 5].map((_, i) => (
         <div key={i} className="trail-img absolute top-0 left-0 w-64 h-80 opacity-0 pointer-events-none rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
            <div className="trail-img-inner w-full h-full bg-gradient-to-br from-nebula/60 to-black/90 flex items-center justify-center p-6 text-white text-center font-display text-xl font-bold">
               NOPROC <br/> UI MODULE {i+1}
            </div>
         </div>
      ))}
    </div>
  );
};

