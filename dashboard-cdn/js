const BlurText = ({ text, delay = 0.5 }) => {
  const words = text.split(' ');
  return (
    <motion.h4 
       initial={{ opacity: 0 }}
       whileInView={{ opacity: 1 }}
       viewport={{ once: true, margin: "-100px" }}
       className="flex flex-wrap text-4xl mb-6 font-display font-bold text-white text-center justify-center justify-self-center mx-auto"
    >
      {words.map((w, i) => (
        <motion.span 
          key={i}
          initial={{ filter: 'blur(10px)', opacity: 0, y: 20 }}
          whileInView={{ filter: 'blur(0px)', opacity: 1, y: 0 }}
          viewport={{ once: true }}
          transition={{ delay: delay + i * 0.1, duration: 0.6, ease: "easeOut" }}
          className="mr-2"
        >
          {w}
        </motion.span>
      ))}
    </motion.h4>
  );
};

