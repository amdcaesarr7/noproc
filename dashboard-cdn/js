// 6. SCROLL FLOAT & REVEAL
// ==========================================
const ScrollFloat = ({ children, className }) => {
  const ref = useRef(null);
  useEffect(() => {
    if (!ref.current) return;
    const chars = ref.current.querySelectorAll('.char');
    gsap.fromTo(chars, 
      { opacity: 0, yPercent: 120, scaleY: 2.3, transformOrigin: '50% 0%' },
      { opacity: 1, yPercent: 0, scaleY: 1, stagger: 0.05, scrollTrigger: { trigger: ref.current, start: 'top bottom-=100', end: 'bottom center', scrub: true } }
    );
  }, []);
  return (
    <div ref={ref} className={`scroll-float ${className}`}>
      <div className="scroll-float-text">
        {children.split('').map((char, i) => <span key={i} className="char">{char === ' ' ? '\u00A0' : char}</span>)}
      </div>
    </div>
  );
};

const ScrollReveal = ({ children, className }) => {
  const ref = useRef(null);
  useEffect(() => {
    if (!ref.current) return;
    const words = ref.current.querySelectorAll('.word');
    gsap.fromTo(words, 
      { opacity: 0.1, filter: 'blur(4px)' },
      { opacity: 1, filter: 'blur(0px)', stagger: 0.05, scrollTrigger: { trigger: ref.current, start: 'top bottom-=20%', end: 'bottom center', scrub: true } }
    );
  }, []);
  return (
    <div ref={ref} className={`scroll-reveal ${className}`}>
      <div className="scroll-reveal-text">
        {children.split(/(\s+)/).map((word, i) => word.trim() ? <span key={i} className="word">{word}</span> : word)}
      </div>
    </div>
  );
};

// ==========================================
// GRADULAR BLUR
// ==========================================
const GradualBlur = ({ position = 'bottom', strength = 2, height = '6rem', zIndex = 1000 }) => {
  const blurDivs = useMemo(() => {
    const divs = []; const count = 5;
    for (let i = 1; i <= count; i++) {
      let progress = i / count;
      let blurValue = 0.0625 * (progress * count + 1) * strength;
      const p1 = Math.round(((i - 1) / count) * 100);
      const p2 = Math.round((i / count) * 100);
      const gradient = `transparent ${p1}%, black ${p2}%`;
      const direction = position === 'bottom' ? 'to bottom' : 'to top';
      divs.push(<div key={i} style={{ position: 'absolute', inset: '0', WebkitMaskImage: `linear-gradient(${direction}, ${gradient})`, WebkitBackdropFilter: `blur(${blurValue}rem)`, backdropFilter: `blur(${blurValue}rem)` }} />);
    }
    return divs;
  }, [position, strength]);

  return (
    <div className="gradual-blur gradual-blur-parent opacity-100" style={{ position: 'absolute', pointerEvents: 'none', zIndex, height, width: '100%', left: 0, [position]: 0 }}>
      {blurDivs}
    </div>
  );
};

